{
  "name": "vue-unwrap",
  "type": "module",
  "version": "2.0.0",
  "description": "Conditional wrapper component for Vue 3 with child ref aggregation.",
  "author": "Andrea 'Fiad' Fiadone <hello@fiad.one>",
  "license": "MIT",
  "homepage": "https://github.com/fiadone/vue-unwrap#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fiadone/vue-unwrap.git"
  },
  "bugs": {
    "url": "https://github.com/fiadone/vue-unwrap/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build",
    "commit": "cz"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tsdown/css": "^0.22.0",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser-playwright": "^4.1.5",
    "bumpp": "^11.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "playwright": "^1.59.1",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unrun": "^0.2.39",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  }
}
